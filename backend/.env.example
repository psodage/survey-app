PORT=4000
NODE_ENV=development

# Render free tier — reduce memory spikes and keep one worker process
# NODE_OPTIONS=--max-old-space-size=384
# WEB_CONCURRENCY=1

# MongoDB Atlas (mongodb+srv://...) or local — either name works:
MONGO_URI=
# MONGODB_URI=

JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated browser origins allowed by CORS (production + local).
# *.vercel.app is also allowed automatically; set this for custom domains.
# FRONTEND_ORIGIN=https://survey-app-chi-wheat.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Password reset OTP (production on Render: use API key — faster than SMTP)
BREVO_API_KEY=
BREVO_FROM_EMAIL=
# Optional SMTP fallback (local dev)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# Optional: first-run seed only (`npm run seed` in backend) — development
# SEED_PASSWORD=Survey@123
