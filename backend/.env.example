PORT=4000
NODE_ENV=development

# MongoDB Atlas (mongodb+srv://...) or local — either name works:
MONGO_URI=
# MONGODB_URI=

JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated browser origins allowed by CORS (production + local):
# FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_FROM_EMAIL=

# Optional: first-run seed only (`npm run seed` in backend) — development
# SEED_PASSWORD=Survey@123
