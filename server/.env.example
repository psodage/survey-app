# MongoDB (Atlas: use mongodb+srv://... with correct host — not the API port)
MONGODB_URI=mongodb://127.0.0.1:27017/survey-app

# API (Vite dev proxies /api here; default target is http://localhost:4000 — override in project root with VITE_API_PROXY_TARGET if needed)
PORT=4000
NODE_ENV=development

# JWT (use a long random string in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS — Vercel frontend URL in production
FRONTEND_ORIGIN=http://localhost:5173

# Cloudinary (site visit photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# First-run seed (npm run seed in /server) — dev only
SEED_PASSWORD=Survey@123

# Optional: npm run add-temp-user (creates/updates a super_admin without wiping DB)
# TEMP_USER_EMAIL=temp@samarth.local
# TEMP_USER_PASSWORD=TempLogin@123
