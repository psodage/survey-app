{
  "name": "samarth-surveyos",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "rollup": "4.60.3"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "preview": "npm run preview -w frontend",
    "start": "npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
