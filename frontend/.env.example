# Production: your Render (or other) API origin — no trailing slash, no `/api` suffix.
# Example: https://samarth-surveyos-api.onrender.com
VITE_API_BASE_URL=

# Local dev: optional override for Vite proxy target (default http://localhost:4000)
# VITE_API_PROXY_TARGET=http://localhost:4000

# Optional: comma-separated hostnames for `npm run dev` (e.g. ngrok tunnel hostname)
# VITE_DEV_ALLOWED_HOSTS=your-app.ngrok-free.dev
